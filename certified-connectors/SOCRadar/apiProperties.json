{
  "properties": {
    "connectionParameters": {
      "api_key": {
        "type": "securestring",
        "uiDefinition": {
          "displayName": "SOCRadar API Key",
          "description": "Your SOCRadar API key (Settings → API Options → Generate Key)",
          "tooltip": "Treat this key as a password",
          "constraints": { "tabIndex": 2, "clearText": false, "required": "true" }
        }
      },
      "company_id": {
        "type": "string",
        "uiDefinition": {
          "displayName": "SOCRadar Company ID",
          "description": "Numeric SOCRadar Company ID (e.g. 22757)",
          "tooltip": "Visible in your SOCRadar dashboard URL",
          "constraints": { "tabIndex": 1, "required": "true" }
        }
      },
      "enforce_mfa": {
        "type": "bool",
        "uiDefinition": {
          "displayName": "Enforce MFA on credential leaks",
          "description": "When enabled, flows using this connection should trigger an MFA reset for any user account found in PII or botnet findings. Recommended: ON.",
          "tooltip": "Enforce multi-factor authentication reset when compromised credentials are detected",
          "constraints": { "tabIndex": 3, "required": "true", "allowedValues": [
            { "text": "Yes — always enforce MFA reset (recommended)", "value": "true" },
            { "text": "No — do not enforce MFA reset", "value": "false" }
          ]}
        }
      },
      "deactivate_user": {
        "type": "bool",
        "uiDefinition": {
          "displayName": "Deactivate compromised accounts",
          "description": "When enabled, flows using this connection may disable the affected user account in addition to MFA enforcement. Use with caution.",
          "tooltip": "Optionally disable the user account when credentials are found in dark web leaks",
          "constraints": { "tabIndex": 4, "required": "false", "allowedValues": [
            { "text": "No — do not deactivate accounts (default)", "value": "false" },
            { "text": "Yes — deactivate compromised accounts", "value": "true" }
          ]}
        }
      }
    },
    "iconBrandColor": "#1A1F36",
    "capabilities": ["actions"],
    "publisher": "SOCRadar",
    "stackOwner": "SOCRadar Inc.",
    "policyTemplateInstances": [
      {
        "title": "Inject API key from connection",
        "templateId": "setheader",
        "parameters": {
          "x-ms-apimTemplateParameter.name": "Api-Key",
          "x-ms-apimTemplateParameter.value": "@connectionParameters('api_key')",
          "x-ms-apimTemplateParameter.existsAction": "override",
          "x-ms-apimTemplate-policySection": "Request"
        }
      },
      {
        "title": "MISA partner User-Agent",
        "templateId": "setheader",
        "parameters": {
          "x-ms-apimTemplateParameter.name": "User-Agent",
          "x-ms-apimTemplateParameter.value": "MdePartner-SOCRadar-LogicAppsConnector/1.0.0",
          "x-ms-apimTemplateParameter.existsAction": "override",
          "x-ms-apimTemplate-policySection": "Request"
        }
      }
    ]
  }
}
