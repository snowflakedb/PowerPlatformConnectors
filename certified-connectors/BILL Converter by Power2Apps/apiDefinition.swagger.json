{
  "swagger": "2.0",
  "info": {
    "title": "BILL Converter by Power2Apps",
    "description": "Processes and transforms electronic invoices in full compliance with ZUGFeRD, XRechnung, EN 16931 and PDF/A-3. Converts XML invoices to PDF, generates ZUGFeRD-compliant hybrid PDF/A-3 documents, and extracts embedded XML from ZUGFeRD or PDF/A-3 files. Supports automated workflows for validating, transforming and exchanging structured e-invoice data across modern e-invoicing ecosystems.",
    "contact": {
      "name": "Power2Apps Support",
      "url": "https://www.power2apps.de/en/contact",
      "email": "getintouch@power2apps.de"
    },
    "version": "1.0.0"
  },
  "host": "converterbypower2appswebapi.orangemoss-ec8ae189.germanywestcentral.azurecontainerapps.io",
