{
  "properties": {
    "capabilities": [
      "actions"
    ],
    "connectionParameters": {
      "token": {
        "type": "oauthSetting",
        "oAuthSettings": {
          "identityProvider": "oauth2",
          "clientId": "<<Enter your client ID>>",
          "scopes": [
            "v1.public"
          ],
          "redirectMode": "Global",
          "redirectUrl": "https://global.consent.azure-apim.net/redirect",
          "properties": {
            "IsFirstParty": "False"
          },
          "customParameters": {
            "grantType": {
              "value": "client_credentials"
            },
            "tokenUrl": {
              "value": "https://identity.redque.com/connect/token"
            }
          }
        },
        "uiDefinition": {
          "displayName": "Redque API Credentials",
          "description": "Authenticate using Client ID and Client Secret",
          "tooltip": "Provide your Redque Client ID and Client Secret",
          "constraints": {
            "required": "true"
          }
        }
      }
    },
    "iconBrandColor": "#000000",
    "publisher": "Redque s.r.o.",
    "stackOwner": "Redque s.r.o."
  }
}
