                "chemicals": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-ms-summary": "Chemicals",
                  "description": "List of chemical names or CAS numbers for which to retrieve occupational exposure limits."
                },
                "region": {
                  "type": "string",
                  "enum": ["US", "EU", "JP", "CN", "INT"],
                  "x-ms-summary": "Region",
