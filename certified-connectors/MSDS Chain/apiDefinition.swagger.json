    "/tools/get_emergency_response": {
      "post": {
        "operationId": "GetEmergencyResponse",
        "summary": "Get emergency response procedures",
        "description": "Returns step-by-step emergency response procedures for a chemical spill, fire, or exposure scenario based on the specified chemical and incident type.",
        "x-ms-summary": "Get emergency response procedures",
        "tags": ["Emergency and Health"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["chemical"],
              "properties": {
                "chemical": {
                  "type": "string",
                  "x-ms-summary": "Chemical",
                  "description": "Name or CAS number of the chemical involved in the emergency."
                },
                "scenario": {
                  "type": "string",
                  "enum": ["spill", "fire", "exposure"],
                  "default": "spill",
                  "x-ms-summary": "Scenario",
                  "description": "Type of emergency scenario: spill, fire, or exposure. Defaults to spill when omitted."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Emergency response procedures retrieved successfully.",
            "schema": {
              "$ref": "#/definitions/ToolResult"
            }
          }
        }
      }
