        "tags": ["Audit and Reporting"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["experiment_name", "chemicals"],
              "properties": {
                "experiment_name": {
                  "type": "string",
                  "x-ms-summary": "Experiment Name",
                  "description": "Human-readable name for this audit session or experiment."
                },
                "chemicals": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-ms-summary": "Chemicals",
                  "description": "List of chemical names or CAS numbers to include in the audit session."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Audit session created successfully.",
            "schema": {
              "$ref": "#/definitions/ToolResult"
            }
          }
        }
