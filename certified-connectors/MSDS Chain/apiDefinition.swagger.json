  "paths": {
    "/tools/check_chemical_compatibility": {
      "post": {
        "operationId": "CheckChemicalCompatibility",
        "summary": "Check chemical compatibility",
        "description": "Performs pairwise compatibility analysis for a list of two or more chemicals using NFPA classification rules and returns hazard combinations.",
        "x-ms-summary": "Check chemical compatibility",
        "tags": ["Safety Assessment"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["chemicals"],
              "properties": {
                "chemicals": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 2,
                  "x-ms-summary": "Chemicals",
                  "description": "List of at least two chemical names or CAS numbers to analyze for compatibility."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Compatibility analysis completed successfully.",
            "schema": {
              "$ref": "#/definitions/ToolResult"
            }
          }
        }
      }
    },
    "/tools/get_chemical_risk_warnings": {
      "post": {
        "operationId": "GetChemicalRiskWarnings",
        "summary": "Get chemical risk warnings",
        "description": "Returns GHS classification details including H-codes, signal words, hazard statements, and flash points for the specified chemicals.",
        "x-ms-summary": "Get chemical risk warnings",
        "tags": ["Safety Assessment"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["chemicals"],
              "properties": {
                "chemicals": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-ms-summary": "Chemicals",
                  "description": "List of chemical names or CAS numbers for which to retrieve GHS risk warnings."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Risk warnings retrieved successfully.",
            "schema": {
              "$ref": "#/definitions/ToolResult"
            }
          }
        }
      }
    },
    "/tools/check_regulatory_compliance": {
      "post": {
        "operationId": "CheckRegulatoryCompliance",
        "summary": "Check regulatory compliance",
        "description": "Checks the regulatory status of chemicals against EU REACH/CLP, US OSHA/TSCA, and other regional frameworks for the specified regions.",
        "x-ms-summary": "Check regulatory compliance",
        "tags": ["Regulatory Compliance"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["chemicals"],
              "properties": {
                "chemicals": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-ms-summary": "Chemicals",
                  "description": "List of chemical names or CAS numbers to check for regulatory compliance."
                },
                "regions": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["EU", "US", "CN", "JP", "KR", "CA", "AU", "TW"]
                  },
                  "x-ms-summary": "Regions",
                  "description": "Optional list of region codes to scope the compliance check (EU, US, CN, JP, KR, CA, AU, TW). Defaults to all regions when omitted."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Regulatory compliance check completed successfully.",
            "schema": {
              "$ref": "#/definitions/ToolResult"
            }
          }
        }
      }
    },
    "/tools/ask_chemical_safety": {
      "post": {
        "operationId": "AskChemicalSafety",
        "summary": "Ask a chemical safety question",
        "description": "Answers a natural language question about chemical safety, hazards, handling, or regulations using the MSDS Chain knowledge base.",
        "x-ms-summary": "Ask a chemical safety question",
