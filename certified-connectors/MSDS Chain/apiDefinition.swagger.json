    "/tools/get_sds_section": {
      "post": {
        "operationId": "GetSdsSection",
        "summary": "Get SDS section",
        "description": "Retrieves a specific section (1 through 16) of the Safety Data Sheet for a chemical, following the GHS 16-section structure.",
        "x-ms-summary": "Get SDS section",
        "tags": ["Data and Research"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["chemical", "section"],
              "properties": {
                "chemical": {
                  "type": "string",
                  "x-ms-summary": "Chemical",
                  "description": "Name or CAS number of the chemical whose SDS section is to be retrieved."
                },
                "section": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 16,
                  "x-ms-summary": "Section Number",
                  "description": "GHS SDS section number to retrieve, from 1 (Identification) to 16 (Other Information)."
                }
              }
            }
          }
