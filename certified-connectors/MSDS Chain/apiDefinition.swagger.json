              "properties": {
                "question": {
                  "type": "string",
                  "x-ms-summary": "Question",
                  "description": "A natural language question about chemical safety, handling, hazards, or regulatory compliance."
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Chemical safety question answered successfully.",
            "schema": {
              "$ref": "#/definitions/ToolResult"
            }
          }
        }
      }
    },
