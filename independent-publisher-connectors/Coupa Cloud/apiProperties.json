{
  "properties": {
    "connectionParameters": {
      "customHost": {
        "type": "string",
        "uiDefinition": {
          "constraints": {
            "tabIndex": 1,
            "required": "true"
          },
          "description": "Coupa instance subdomain only \u2014 e.g. mycompany-test",
          "displayName": "Coupa Instance Name",
          "tooltip": "e.g. mycompany-test"
        }
      },
      "domain": {
        "type": "string",
        "uiDefinition": {
          "constraints": {
            "tabIndex": 2,
            "required": "true",
            "allowedValues": [
              {
                "text": "coupahost.com",
                "value": "coupahost.com"
              },
              {
                "text": "coupacloud.com",
                "value": "coupacloud.com"
              }
            ]
          },
          "description": "Select your Coupa domain",
          "displayName": "Coupa Domain",
          "tooltip": "coupahost.com is standard; coupacloud.com is used by some tenants"
        }
      }
    },
    "iconBrandColor": "#da3b01",
    "capabilities": [
      "actions"
    ],
    "policyTemplateInstances": [
      {
        "templateId": "dynamichosturl",
        "title": "Set Coupa host from connection parameter",
        "parameters": {
          "x-ms-apimTemplateParameter.urlTemplate": "https://@connectionParameters('customHost').@connectionParameters('domain')/api"
        }
      },
      {
        "templateId": "setheader",
        "title": "Accept: application/json",
        "parameters": {
          "x-ms-apimTemplateParameter.name": "Accept",
          "x-ms-apimTemplateParameter.value": "application/json",
          "x-ms-apimTemplateParameter.existsAction": "override",
          "x-ms-apimTemplate-policySection": "Request"
        }
      },
      {
        "templateId": "setheader",
        "title": "Rewrite Access-Token to Authorization",
        "parameters": {
          "x-ms-apimTemplateParameter.name": "Authorization",
          "x-ms-apimTemplateParameter.value": "@headers('Access-Token')",
          "x-ms-apimTemplateParameter.existsAction": "override",
          "x-ms-apimTemplate-policySection": "Request"
        }
      }
    ],
    "publisher": "NovaGL",
    "stackOwner": "Coupa Software"
  }
}