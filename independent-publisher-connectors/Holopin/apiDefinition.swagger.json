                "summary": "Issue badge with custom image (Beta)",
                "description": "Issue a badge with a custom image per recipient. This is an experimental beta feature.",
                "operationId": "IssueBadgeCustomImage",
                "x-ms-summary": "Issue Badge with Custom Image",
                "x-ms-visibility": "advanced",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "x-ms-summary": "Sticker ID",
                        "description": "The sticker identifier.",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": false,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "email": {
                                    "type": "string",
                                    "description": "The recipient's email address. If provided, the recipient will receive an email with a link to claim the badge.",
                                    "title": "Email",
                                    "x-ms-summary": "Email"
                                },
                                "image": {
                                    "type": "string",
                                    "description": "The PNG image to be used for the badge. Data can be a URL or a base64 encoded image (mime:image/png data:string format).",
                                    "title": "Image",
                                    "x-ms-summary": "Image"
                                },
                                "metadata": {
                                    "type": "string",
                                    "description": "Optional metadata for the coupon.",
                                    "title": "Metadata",
                                    "x-ms-summary": "Metadata"
                                }
                            }
                        }
                    }
                ]
            },
