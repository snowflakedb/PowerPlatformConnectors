{
    "swagger": "2.0",
    "info": {
        "title": "Holopin",
        "description": "Holopins are digital badges, but actually cool. Earn verifiable digital badges for skills, achievements, and all the amazing things you do. Build collections and create your own badge board.",
        "version": "1.1",
        "contact": {
            "name": "Troy Taylor",
            "email": "troy@troystaylor.com"
        }
    },
    "host": "www.holopin.io",
    "basePath": "/api/",
    "schemes": [
        "https"
    ],
    "consumes": [
        "application/json"
    ],
    "produces": [
        "application/json"
    ],
    "paths": {
        "/sticker/share": {
            "post": {
                "responses": {
                    "200": {
                        "description": "Success",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "The message.",
                                    "title": "Message",
                                    "x-ms-summary": "Message"
                                },
                                "data": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "string",
                                            "description": "The coupon identifier.",
                                            "title": "Coupon ID",
                                            "x-ms-summary": "Coupon ID"
                                        },
                                        "stickerId": {
                                            "type": "string",
                                            "description": "The sticker identifier.",
                                            "title": "Sticker ID",
                                            "x-ms-summary": "Sticker ID"
                                        },
                                        "metadata": {
                                            "type": "string",
                                            "description": "The metadata.",
                                            "title": "Metadata",
                                            "x-ms-summary": "Metadata"
                                        }
                                    },
                                    "title": "Data",
                                    "description": "The data."
                                }
                            }
                        }
                    }
                },
                "summary": "Issue a badge",
                "description": "Issue a regular (static) badge and retrieve the coupon identifier for the badge.",
                "operationId": "IssueBadge",
                "x-ms-summary": "Issue a Badge",
                "x-ms-visibility": "important",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "x-ms-summary": "Sticker ID",
                        "description": "The sticker identifier.",
                        "required": true,
                        "type": "string",
                        "x-ms-visibility": "important"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": false,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "email": {
                                    "type": "string",
                                    "description": "The recipient's email address. If provided, the recipient will receive an email with a link to claim the badge.",
                                    "title": "Email",
                                    "x-ms-summary": "Email"
                                },
                                "metadata": {
                                    "type": "string",
                                    "description": "Optional metadata for the coupon.",
                                    "title": "Metadata",
                                    "x-ms-summary": "Metadata"
                                }
                            }
                        }
                    }
                ]
            }
        },
        "/holobyte": {
            "post": {
                "responses": {
                    "200": {
                        "description": "Success",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "description": "The holobyte identifier.",
                                    "title": "Holobyte ID",
                                    "x-ms-summary": "Holobyte ID"
                                },
                                "evolvingStickerId": {
                                    "type": "string",
                                    "description": "The evolving sticker identifier.",
                                    "title": "Evolving Sticker ID",
                                    "x-ms-summary": "Evolving Sticker ID"
                                },
                                "metadata": {
                                    "type": "string",
                                    "description": "The metadata.",
                                    "title": "Metadata",
                                    "x-ms-summary": "Metadata"
                                }
                            }
                        }
                    }
                },
                "summary": "Issue a holobyte",
                "description": "Issue a unique holobyte (progress point) for an evolving badge or as a standalone reward.",
                "operationId": "IssueHolobyte",
                "x-ms-summary": "Issue a Holobyte",
                "x-ms-visibility": "important",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "x-ms-summary": "Evolving Sticker ID",
                        "description": "The evolving sticker identifier. Omit this parameter to issue a standalone holobyte.",
                        "required": false,
                        "type": "string",
                        "x-ms-visibility": "advanced"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": false,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "username": {
                                    "type": "string",
                                    "description": "Holopin username of the recipient.",
                                    "title": "Username",
                                    "x-ms-summary": "Username"
                                },
                                "toGithubId": {
                                    "type": "string",
                                    "description": "GitHub ID of the recipient.",
                                    "title": "GitHub ID",
                                    "x-ms-summary": "GitHub ID"
                                },
                                "toDiscordId": {
                                    "type": "string",
                                    "description": "Discord ID of the recipient.",
                                    "title": "Discord ID",
                                    "x-ms-summary": "Discord ID"
                                },
                                "icon": {
                                    "type": "string",
                                    "description": "Icon for the holobyte. Available options: lemon, cherry, coffee, starfruit, avocado. Defaults to lemon.",
                                    "title": "Icon",
                                    "x-ms-summary": "Icon",
                                    "enum": [
                                        "lemon",
                                        "cherry",
                                        "coffee",
                                        "starfruit",
                                        "avocado"
                                    ],
                                    "default": "lemon"
                                },
                                "description": {
                                    "type": "string",
                                    "description": "What the holobyte was issued for.",
                                    "title": "Description",
                                    "x-ms-summary": "Description"
                                },
                                "url": {
                                    "type": "string",
                                    "description": "URL reference of where the holobyte was earned.",
                                    "title": "URL",
                                    "x-ms-summary": "URL"
                                },
                                "urlAlias": {
                                    "type": "string",
                                    "description": "Alternative name for the URL reference.",
                                    "title": "URL Alias",
                                    "x-ms-summary": "URL Alias"
                                },
                                "fromAlias": {
                                    "type": "string",
                                    "description": "A specific person's or team's name who you want to appear as the issuer.",
                                    "title": "From Alias",
                                    "x-ms-summary": "From Alias"
                                },
                                "fromAliasUrl": {
                                    "type": "string",
                                    "description": "A URL reference for the issuer.",
                                    "title": "From Alias URL",
                                    "x-ms-summary": "From Alias URL"
                                },
                                "metadata": {
                                    "type": "string",
                                    "description": "Optional metadata for the holobyte.",
                                    "title": "Metadata",
                                    "x-ms-summary": "Metadata"
                                }
                            }
                        }
                    }
                ]
            }
        },
