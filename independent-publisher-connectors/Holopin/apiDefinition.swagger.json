                                },
                                "username": {
                                    "type": "string",
                                    "description": "The Holopin username.",
                                    "title": "Username",
                                    "x-ms-summary": "Username"
                                },
                                "email": {
                                    "type": "string",
                                    "description": "The email address if the badge was sent via email.",
                                    "title": "Email",
                                    "x-ms-summary": "Email"
                                },
                                "url": {
                                    "type": "string",
                                    "description": "The user's claimed badge URL.",
                                    "title": "URL",
                                    "x-ms-summary": "URL"
                                }
                            }
                        }
                    }
