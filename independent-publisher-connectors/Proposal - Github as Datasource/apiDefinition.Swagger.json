{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "GitHub Data",
    "description": "To use the files on your GitHub repo as a datasource, for example if your website is hosted on GitHub. Not to be confused with the other GitHub connector that focuses on the PR's.",
    "contact": {
      "name": "Nathalie Leenders",
      "url": "https://www.nathalieleenders.com",
      "email": "info@nathalieleenders.com"
    }
  },
  "host": "raw.GitHubusercontent.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {},
  "x-ms-connector-metadata": [
    {
      "propertyName": "Website",
      "propertyValue": "https://www.nathalieleenders.com"
    },
    {
      "propertyName": "Privacy policy",
      "propertyValue": "https://www.nathalieleenders.com"
    },
    {
      "propertyName": "Publisher",
      "propertyValue": "Nathalie Leenders"
    },
    {
      "propertyName": "Categories",
      "propertyValue": "IT Operations"
    }
  ],
  "paths": {
    "/{GitHubname}/{Reponame}/{Filewithpath}": {
      "get": {
        "summary": "Get file",
        "description": "To use the files on your GitHub repo as a datasource, for example if your website is hosted on GitHub. Not to be confused with the other GitHub connector that focuses on the PR's.",
        "operationId": "RetrieveData",
        "parameters": [
          {
            "name": "GitHubname",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "GitHub name",
            "description": "The name of the GitHub user",
            "x-ms-url-encoding": "single"
          },
          {
            "name": "Reponame",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "Repository name",
            "description": "The name of the GitHub repository",
            "x-ms-url-encoding": "single"
          },
          {
            "name": "Filewithpath",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "File with path",
            "description": "The path to the file in the repository, including the file name",
            "x-ms-url-encoding": "single"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "string"
            }
          },
          "404": {
            "description": "Not found"
          },
          "429": {
            "description": "Service limit exhausted. Please contact your team admin."
          }
        }
      }
    }
  }
}